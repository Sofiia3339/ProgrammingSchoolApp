@model ProgrammingSchoolApp.Models.Course

@{
    ViewData["Title"] = "Видалення курсу";
}

<div class="container mt-4">
    <h1 class="text-danger fw-bold mb-4">Видалення курсу</h1>
    
    <div class="alert alert-warning shadow-sm" role="alert">
        <h4 class="alert-heading">Увага!</h4>
        <p>Ви впевнені, що хочете назавжди видалити цей курс? Цю дію неможливо скасувати.</p>
    </div>

    <div class="card border-danger mb-4 shadow-sm">
        <div class="card-body">
            <h3 class="card-title fw-bold">@Model.Title</h3>
            <p class="card-text">@Model.Description</p>
            <p class="card-text"><strong class="fs-5">Ціна: @Model.Price ₴</strong></p>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Так, видалити назавжди" class="btn btn-danger btn-lg" />
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">Ні, повернутися назад</a>
    </form>
</div>