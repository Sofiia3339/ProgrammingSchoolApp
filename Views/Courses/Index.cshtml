@model IEnumerable<ProgrammingSchoolApp.Models.Course>

@{
    ViewData["Title"] = "Каталог курсів";
}

<div class="d-flex justify-content-between align-items-center mb-5 flex-wrap">
    <h1 class="fw-bold" style="color: #1c1d1f;">Всі курси</h1>
    
<div class="d-flex gap-2 align-items-center">
    <a asp-action="ExportPriceHistoryToExcel" class="btn btn-outline-success">📥 Звіт цін (Excel)</a>
    <a asp-action="ExportPriceHistoryToWord" class="btn btn-outline-primary">📄 Звіт цін (Word)</a>
    <a asp-action="Create" class="btn btn-dark fw-bold" style="background-color: #1c1d1f;">+ Додати курс</a>
</div>

<div class="card mb-4 shadow-sm border-0 bg-light">
    <div class="card-body">
        <form asp-action="ImportFromExcel" enctype="multipart/form-data" method="post" class="d-flex align-items-center gap-3">
            <label class="fw-bold mb-0">Завантажити з Excel:</label>
            <input type="file" name="fileExcel" class="form-control w-auto" accept=".xlsx" required />
            <button type="submit" class="btn btn-success">Завантажити</button>
        </form>
    </div>
</div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model) {
            <div class="col">
                <div class="card h-100 shadow-sm transition-hover" style="border: 1px solid #d1d7dc; border-radius: 0;">
                    
                    <img src="https://placehold.co/600x340/2d2f31/ffffff?font=montserrat&text=IT+Course" class="card-img-top" alt="Обкладинка курсу" style="border-radius: 0; object-fit: cover; height: 180px;">
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold mb-2" style="color: #1c1d1f; font-size: 1.1rem;">
                            @item.Title
                        </h5>
                        <p class="card-text text-muted flex-grow-1" style="font-size: 0.9rem;">
                            @(item.Description != null && item.Description.Length > 90 ? item.Description.Substring(0, 90) + "..." : item.Description)
                        </p>
                        <div class="mt-2 mb-3">
                            <span class="fw-bold" style="font-size: 1.2rem; color: #1c1d1f;">@item.Price ₴</span>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-white pb-3 pt-0" style="border-top: none;">
                        <div class="d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark fw-bold" style="border-radius: 0;">Переглянути курс</a>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border">Редагувати</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-danger">Видалити</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<div class="container mt-5 mb-5">
    <h2 class="fw-bold mb-4" style="color: #1c1d1f;">Аналітика: Вартість курсів</h2>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div id="chart_div" style="width: 100%; height: 400px;"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', {'packages':['corechart']});
        google.charts.setOnLoadCallback(drawChart);

        function drawChart() {
            fetch('/Courses/GetChartData')
                .then(response => response.json())
                .then(data => {
                    var dataTable = new google.visualization.DataTable();
                    dataTable.addColumn('string', 'Курс');
                    dataTable.addColumn('number', 'Ціна (грн)');

                    data.forEach(item => {
                        dataTable.addRow([item.title, item.price]);
                    });
                    var options = {
                        title: 'Порівняння вартості курсів',
                        hAxis: {title: 'Назва курсу', titleTextStyle: {color: '#333'}},
                        vAxis: {title: 'Ціна (грн)', minValue: 0},
                        colors: ['#1c1d1f'],
                        animation: {
                            startup: true,
                            duration: 1000,
                            easing: 'out'
                        },
                        legend: { position: "none" }
                    };
                    var chart = new google.visualization.ColumnChart(document.getElementById('chart_div'));
                    chart.draw(dataTable, options);
                });
        }
    </script>
}